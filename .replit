modules = ["nodejs-20", "python-3.11", "python3", "postgresql-16"]

[nix]
channel = "stable-24_05"
packages = ["jq"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "ProxyServer"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "CraveMobile"

[[workflows.workflow]]
name = "ProxyServer"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node proxy-server.js"
waitForPort = 5000

[[workflows.workflow]]
name = "CraveMobile"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "yes | npx expo start --tunnel"
waitForPort = 8081

[workflows.workflow.metadata]
outputType = "console"

[deployment]
run = ["node", "proxy-server.js"]
deploymentTarget = "autoscale"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3001

[agent]
expertMode = true

[userenv]

[userenv.shared]
