modules = ["nodejs-20", "python-3.11", "python3", "postgresql-16"]

[nix]
channel = "stable-24_05"
packages = ["jq"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "ProxyServer"

[[workflows.workflow]]
name = "ProxyServer"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node proxy-server.js"
waitForPort = 5000

[deployment]
run = ["node", "proxy-server.js"]
deploymentTarget = "vm"

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 8000
externalPort = 80

[agent]
expertMode = true

[userenv]

[userenv.shared]
